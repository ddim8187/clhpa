@echo off
chcp 65001 > nul
setlocal
set "TMPPS=%TEMP%\install_clhpa_%RANDOM%.ps1"

powershell -NoProfile -ExecutionPolicy Bypass -Command "$f=[IO.File]::ReadAllLines('%~f0',[Text.Encoding]::UTF8);$s=[Array]::IndexOf($f,'::PS1START::');$e=[Array]::IndexOf($f,'::PS1END::');if($s-lt 0-or$e-lt 0){Write-Host '마커 오류' -ForegroundColor Red;exit 1;}[IO.File]::WriteAllText('%TMPPS%',[string]::Join([char]10,$f[($s+1)..($e-1)]),[Text.Encoding]::UTF8)"

if not exist "%TMPPS%" (
    echo [오류] 설치 파일 추출 실패.
    pause
    exit /b 1
)

powershell -NoProfile -ExecutionPolicy Bypass -File "%TMPPS%"
del "%TMPPS%" 2>nul
endlocal
exit /b

